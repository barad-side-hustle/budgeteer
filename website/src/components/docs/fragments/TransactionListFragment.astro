---
interface Row {
  icon: string;
  iconClass: 'cof' | 'gro' | 'tra' | 'sub' | 'sho';
  merchant: string;
  category: string;
  amount: string;
}
interface Props { rows?: Row[]; }
const {
  rows = [
    { icon: '☕', iconClass: 'cof', merchant: 'Aroma · Rothschild', category: '✨ Coffee', amount: '−₪14.50' },
    { icon: '🛒', iconClass: 'gro', merchant: 'Shufersal Deal', category: '✨ Groceries', amount: '−₪284.20' },
    { icon: '🚇', iconClass: 'tra', merchant: 'Rav-Kav', category: '✨ Transport', amount: '−₪124.00' },
  ],
} = Astro.props;
---
<div class="docs-frag-cat">
  {rows.map(r => (
    <div class="tx-row">
      <div class={`ico ${r.iconClass}`}>{r.icon}</div>
      <div class="body">
        <span class="merchant">{r.merchant}</span>
        <span class="cat-pill">{r.category}</span>
      </div>
      <span class="amount">{r.amount}</span>
    </div>
  ))}
</div>

<style>
.docs-frag-cat {
  background: var(--budgeteer-card);
  border: 1px solid var(--budgeteer-border);
  border-radius: 12px;
  overflow: hidden;
  box-shadow: var(--budgeteer-shadow-card);
  max-width: 26rem;
  margin: 1.5rem 0;
}
.docs-frag-cat .tx-row {
  padding: 12px 14px;
  border-bottom: 1px solid var(--budgeteer-border);
  display: flex;
  align-items: center;
  gap: 10px;
}
.docs-frag-cat .tx-row:last-child { border-bottom: none; }
.docs-frag-cat .ico {
  width: 28px; height: 28px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; color: #fff; font-size: 13px;
}
.docs-frag-cat .ico.cof { background: var(--budgeteer-orange); }
.docs-frag-cat .ico.gro { background: var(--budgeteer-vibrant); color: var(--budgeteer-primary); }
.docs-frag-cat .ico.tra { background: var(--budgeteer-blue); }
.docs-frag-cat .ico.sub { background: var(--budgeteer-pink); color: var(--budgeteer-primary); }
.docs-frag-cat .ico.sho { background: var(--budgeteer-primary); }
.docs-frag-cat .body { flex: 1; display: flex; flex-direction: column; gap: 1px; min-width: 0; }
.docs-frag-cat .merchant { font-weight: 600; color: var(--budgeteer-fg); font-size: 0.85rem; font-family: var(--budgeteer-font-sans); }
.docs-frag-cat .cat-pill {
  font-family: var(--budgeteer-font-mono);
  font-size: 0.55rem;
  color: var(--budgeteer-vibrant);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.docs-frag-cat .amount {
  font-family: var(--budgeteer-font-mono);
  font-size: 0.8rem;
  color: var(--budgeteer-orange);
  font-weight: 600;
}
</style>
