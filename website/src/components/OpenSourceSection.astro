---
const REPO_URL = 'https://github.com/barad-side-hustle/budgeteer';
---
<section class="oss budgeteer-fade-up">
	<div class="deco deco-circle-vibrant" aria-hidden="true"></div>
	<div class="deco deco-ring-blue" aria-hidden="true"></div>
	<div class="deco deco-dot-orange" aria-hidden="true"></div>
	<div class="deco deco-circle-pink" aria-hidden="true"></div>

	<div class="budgeteer-wrap">
		<div class="intro">
			<div class="budgeteer-eyebrow center">Built in the open</div>
			<h2 class="display">
				<span class="budgeteer-serif-ital">Free as in </span>
				<span class="budgeteer-sans-bold">freedom.</span>
			</h2>
			<p>
				Budgeteer is fully open source under MIT. Read the code, fork it, contribute back, or just
				verify that what it claims about your privacy is actually true.
			</p>
			<a class="view-link" href={REPO_URL}>
				View on GitHub
				<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<line x1="7" y1="17" x2="17" y2="7"/>
					<polyline points="7 7 17 7 17 17"/>
				</svg>
			</a>
		</div>

		<div class="card-row">
			<div class="repo-card">
				<div class="row1">
					<div class="gh-icon" aria-hidden="true">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
							<path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
						</svg>
					</div>
					<div class="repo-name">alon710<span>/</span>Budgeteer</div>
				</div>
				<div class="desc">A local-only personal finance tracker for Israeli banks. Beautiful, private, open source.</div>
				<div class="stats">
					<span class="stat lang">TypeScript</span>
					<span class="stat">
						<svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
						</svg>
						Star us
					</span>
					<span class="stat">MIT</span>
				</div>
				<a class="cta" href={REPO_URL}>
					<svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
						<path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
					</svg>
					Star on GitHub
				</a>
			</div>

			<div class="terminal" aria-hidden="true">
				<div class="terminal-bar">
					<span class="tdot red"></span>
					<span class="tdot yellow"></span>
					<span class="tdot green"></span>
					<span class="terminal-title">~/projects</span>
				</div>
				<div class="terminal-body">
					<div class="tline"><span class="prompt">$</span> <span class="cmd">git clone github.com/barad-side-hustle/budgeteer</span></div>
					<div class="tline out">Cloning into 'Budgeteer'... done.</div>
					<div class="tline"><span class="prompt">$</span> <span class="cmd">cd Budgeteer &amp;&amp; npm install</span></div>
					<div class="tline out">added 384 packages in 9s</div>
					<div class="tline"><span class="prompt">$</span> <span class="cmd">npm run setup</span></div>
					<div class="tline out">=&gt; Installing background service…</div>
					<div class="tline out">=&gt; Building menubar app…</div>
					<div class="tline vibrant">▲ Budgeteer is live at <u>budgeteer.localhost:2412</u></div>
					<div class="tline"><span class="prompt">$</span> <span class="cursor"></span></div>
				</div>
			</div>
		</div>
	</div>
</section>



<style>
	.oss {
		padding: 5rem 0;
		border-bottom: 1px solid var(--budgeteer-border);
		background: var(--budgeteer-bg);
		position: relative;
		overflow: hidden;
	}
	.deco {
		position: absolute;
		pointer-events: none;
	}
	.deco-circle-vibrant {
		top: 10%; left: 6%;
		width: 64px; height: 64px;
		border-radius: 50%;
		background: var(--budgeteer-vibrant);
		opacity: 0.85;
	}
	.deco-ring-blue {
		top: 18%; right: 8%;
		width: 48px; height: 48px;
		border-radius: 50%;
		border: 3px solid var(--budgeteer-blue);
	}
	.deco-dot-orange {
		bottom: 22%; left: 12%;
		width: 14px; height: 14px;
		border-radius: 50%;
		background: var(--budgeteer-orange);
	}
	.deco-circle-pink {
		bottom: 14%; right: 14%;
		width: 56px; height: 56px;
		border-radius: 50%;
		background: var(--budgeteer-pink);
	}
	@media (max-width: 48rem) {
		.deco-ring-blue, .deco-dot-orange { display: none; }
		.deco-circle-vibrant, .deco-circle-pink { transform: scale(0.6); }
	}
	.intro {
		max-width: 36rem;
		margin: 0 auto 2.5rem;
		text-align: center;
	}
	.display {
		font-size: clamp(2rem, 4vw, 2.5rem);
		line-height: 1.05;
		margin: 0 0 1rem;
	}
	.intro p {
		font-family: var(--budgeteer-font-sans);
		font-size: 0.95rem;
		line-height: 1.6;
		color: var(--budgeteer-fg-muted);
		max-width: 28rem;
		margin: 0 auto 1.25rem;
	}
	.card-row {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.25rem;
		max-width: 60rem;
		margin: 0 auto;
		align-items: stretch;
	}
	@media (min-width: 60rem) {
		.card-row { grid-template-columns: 1fr 1fr; gap: 1.5rem; }
	}
	.view-link {
		font-family: var(--budgeteer-font-serif);
		font-style: italic;
		color: var(--budgeteer-primary);
		font-size: 0.95rem;
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
	}
	.view-link:hover { text-decoration: underline; text-underline-offset: 3px; }

	.repo-card {
		background: var(--budgeteer-card);
		border: 1px solid var(--budgeteer-border);
		border-radius: var(--budgeteer-radius);
		padding: 1.4rem;
		font-family: var(--budgeteer-font-sans);
		transition: transform 180ms ease;
	}
	.repo-card:hover { transform: translateY(-2px); }
	.row1 {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		margin-bottom: 0.75rem;
	}
	.gh-icon {
		width: 28px;
		height: 28px;
		background: var(--budgeteer-primary);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--budgeteer-bg);
		flex-shrink: 0;
	}
	.repo-name {
		font-family: var(--budgeteer-font-mono);
		font-size: 0.825rem;
		color: var(--budgeteer-fg);
	}
	.repo-name span { color: var(--budgeteer-fg-muted); }
	.desc {
		font-size: 0.825rem;
		color: var(--budgeteer-fg-muted);
		line-height: 1.55;
		margin-bottom: 0.85rem;
	}
	.stats {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		font-family: var(--budgeteer-font-mono);
		font-size: 0.7rem;
		color: var(--budgeteer-fg);
		padding-top: 0.75rem;
		border-top: 1px solid var(--budgeteer-border);
	}
	.stat {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
	}
	.stat svg { color: var(--budgeteer-orange); }
	.stat.lang::before {
		content: '';
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: var(--budgeteer-primary);
	}
	.cta {
		margin-top: 1rem;
		background: var(--budgeteer-primary);
		color: var(--budgeteer-bg);
		border-radius: 100px;
		padding: 0.65rem 1.1rem;
		font-size: 0.75rem;
		font-weight: 500;
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		text-decoration: none;
		transition: background 180ms ease, transform 180ms ease;
		align-self: flex-start;
	}
	.cta:hover {
		background: var(--budgeteer-primary-dark);
		transform: translateY(-1px);
	}

	/* === Terminal === */
	.terminal {
		background: var(--budgeteer-primary-dark);
		border-radius: var(--budgeteer-radius);
		overflow: hidden;
		box-shadow: var(--budgeteer-shadow-card);
		font-family: var(--budgeteer-font-mono);
		display: flex;
		flex-direction: column;
	}
	.terminal-bar {
		background: rgba(255, 255, 255, 0.06);
		padding: 0.65rem 0.9rem;
		display: flex;
		align-items: center;
		gap: 0.4rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
	}
	.tdot {
		width: 11px;
		height: 11px;
		border-radius: 50%;
	}
	.tdot.red    { background: #FF5F57; }
	.tdot.yellow { background: #FEBC2E; }
	.tdot.green  { background: #28C840; }
	.terminal-title {
		margin-left: auto;
		font-size: 0.7rem;
		color: rgba(255, 255, 255, 0.4);
		letter-spacing: 0.05em;
	}
	.terminal-body {
		padding: 1rem 1.1rem 1.1rem;
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		font-size: 0.78rem;
		line-height: 1.5;
	}
	.tline {
		color: rgba(255, 255, 255, 0.92);
		display: flex;
		gap: 0.5rem;
		align-items: baseline;
	}
	.tline .prompt {
		color: var(--budgeteer-vibrant);
		font-weight: 600;
		flex-shrink: 0;
	}
	.tline .cmd { color: rgba(255, 255, 255, 0.95); }
	.tline.out  { color: rgba(255, 255, 255, 0.5); padding-left: 1rem; }
	.tline.vibrant { color: var(--budgeteer-vibrant); padding-left: 1rem; }
	.tline.vibrant u {
		text-decoration: underline;
		text-decoration-color: var(--budgeteer-vibrant);
		text-underline-offset: 2px;
	}
	.cursor {
		display: inline-block;
		width: 8px;
		height: 1em;
		background: var(--budgeteer-vibrant);
		animation: terminal-blink 1.1s steps(2, start) infinite;
		vertical-align: middle;
	}
	@keyframes terminal-blink {
		to { visibility: hidden; }
	}
	@media (prefers-reduced-motion: reduce) {
		.cursor { animation: none; }
	}
</style>
