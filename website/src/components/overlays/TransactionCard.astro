---
interface Props {
	merchant: string;
	category: string;
	amount: string;
	rotate?: number;
	delay?: number;
	class?: string;
}
const { merchant, category, amount, rotate = -3, delay = 0, class: className = '' } = Astro.props;
const style = `--budgeteer-rot: rotate(${rotate}deg); transform: var(--budgeteer-rot); animation-delay: ${delay}s;`;
---
<div class={`overlay-card overlay-tx ${className}`} style={style}>
	<div class="ico" aria-hidden="true">
		<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<path d="M18 8h1a4 4 0 0 1 0 8h-1"/>
			<path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/>
			<line x1="6" y1="1" x2="6" y2="4"/>
			<line x1="10" y1="1" x2="10" y2="4"/>
			<line x1="14" y1="1" x2="14" y2="4"/>
		</svg>
	</div>
	<div class="text">
		<span class="merchant">{merchant}</span>
		<span class="cat">{category}</span>
	</div>
	<span class="amount">{amount}</span>
</div>

<style>
	.overlay-card {
		position: absolute;
		background: #fff;
		border-radius: 12px;
		padding: 12px 14px;
		box-shadow: var(--budgeteer-shadow-overlay);
		font-family: var(--budgeteer-font-sans);
		font-size: 0.75rem;
		z-index: 3;
		animation: budgeteer-float 6s ease-in-out infinite;
	}
	.overlay-tx {
		display: flex;
		align-items: center;
		gap: 0.625rem;
		min-width: 220px;
	}
	.ico {
		width: 36px;
		height: 36px;
		border-radius: 50%;
		background: var(--budgeteer-vibrant);
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		color: var(--budgeteer-primary);
	}
	.text { display: flex; flex-direction: column; gap: 2px; }
	.merchant { font-weight: 600; color: var(--budgeteer-fg); }
	.cat {
		font-family: var(--budgeteer-font-mono);
		font-size: 0.5625rem;
		color: var(--budgeteer-fg-muted);
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}
	.amount {
		margin-left: auto;
		font-family: var(--budgeteer-font-mono);
		font-weight: 600;
		color: var(--budgeteer-orange);
	}
</style>
